generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  name      String   @map("name") @db.VarChar(255)
  email     String   @unique @map("email") @db.VarChar(255)
  password  String   @map("password") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets        Tickets[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]

  @@map("users")
}

model Tickets {
  id          Int          @id @default(autoincrement())
  uuid        String       @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  title       String       @map("title") @db.VarChar(255)
  description String       @map("description") @db.VarChar(255)
  status      TicketStatus @default(OPEN) @map("status")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  userId      Int          @map("user_id")

  user          User           @relation(fields: [userId], references: [id])
  notifications Notification[]

  @@map("tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model Notification {
  id        Int                 @id @default(autoincrement())
  uuid      String              @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  channel   NotificationChannel @map("channel")
  recipient String              @map("recipient") @db.VarChar(255)
  subject   String              @map("subject") @db.VarChar(255)
  body      String              @map("body") @db.Text
  status    NotificationStatus  @default(PENDING) @map("status")
  ticketId  Int                 @map("ticket_id")
  userId    Int                 @map("user_id")
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  ticket Tickets @relation(fields: [ticketId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @map("token_hash") @db.VarChar(64)
  familyId  String    @map("family_id") @db.VarChar(36)
  userId    Int       @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([familyId])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  tokenHash String    @map("token_hash") @db.VarChar(64)
  userId    Int       @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_resets")
}

model Country {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  name      String   @map("name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  states State[]

  @@map("countries")
}

model State {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  name      String   @map("name") @db.VarChar(255)
  code      String?  @map("code") @db.VarChar(10)
  countryId Int      @map("country_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  cities  City[]

  clients         Client[]         @relation("ClientAddressState")
  clientContracts ClientContract[] @relation("ContractAddressState")

  @@unique([countryId, name])
  @@unique([countryId, code])
  @@index([countryId])
  @@map("states")
}

model City {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  name      String   @map("name") @db.VarChar(255)
  stateId   Int      @map("state_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  state State @relation(fields: [stateId], references: [id], onDelete: Restrict)

  clients         Client[]         @relation("ClientAddressCity")
  clientContracts ClientContract[] @relation("ContractAddressCity")

  @@unique([stateId, name])
  @@index([stateId])
  @@map("cities")
}

model Client {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  name         String   @map("name") @db.VarChar(255)
  cpf          String?  @unique @map("cpf") @db.VarChar(11)
  cnpj         String?  @unique @map("cnpj") @db.VarChar(14)
  street       String   @map("street") @db.VarChar(255)
  number       String   @map("address_number") @db.VarChar(20)
  complement   String?  @map("complement") @db.VarChar(100)
  neighborhood String   @map("neighborhood") @db.VarChar(100)
  city         String?  @map("city") @db.VarChar(100)
  state        String?  @map("state") @db.VarChar(10)
  zipCode      String   @map("zip_code") @db.VarChar(8)
  stateId      Int?     @map("state_id")
  cityId       Int?     @map("city_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addressState State? @relation("ClientAddressState", fields: [stateId], references: [id], onDelete: Restrict)
  addressCity  City?  @relation("ClientAddressCity", fields: [cityId], references: [id], onDelete: Restrict)

  contracts ClientContract[]

  @@index([stateId])
  @@index([cityId])
  @@map("clients")
}

enum ClientContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model ClientContract {
  id               Int                  @id @default(autoincrement())
  uuid             String               @unique @default(uuid()) @map("uuid") @db.VarChar(36)
  contractNumber   String               @map("contract_number") @db.VarChar(100)
  clientId         Int                  @map("client_id")
  useClientAddress Boolean              @default(true) @map("use_client_address")
  street           String?              @map("street") @db.VarChar(255)
  number           String?              @map("address_number") @db.VarChar(20)
  complement       String?              @map("complement") @db.VarChar(100)
  neighborhood     String?              @map("neighborhood") @db.VarChar(100)
  city             String?              @map("city") @db.VarChar(100)
  state            String?              @map("state") @db.VarChar(10)
  zipCode          String?              @map("zip_code") @db.VarChar(8)
  stateId          Int?                 @map("state_id")
  cityId           Int?                 @map("city_id")
  startDate        DateTime             @map("start_date")
  endDate          DateTime?            @map("end_date")
  status           ClientContractStatus @default(ACTIVE) @map("status")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  client         Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contractState  State? @relation("ContractAddressState", fields: [stateId], references: [id], onDelete: Restrict)
  contractCity   City?  @relation("ContractAddressCity", fields: [cityId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([stateId])
  @@index([cityId])
  @@map("client_contracts")
}
