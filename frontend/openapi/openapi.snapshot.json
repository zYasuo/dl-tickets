{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/users": {
      "post": {
        "operationId": "UserController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserBodyDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created. Actual response wraps payload in `{ success, timestamp, data }` (see schema).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserCreatedEnvelopeOpenApiDto"
                }
              }
            }
          },
          "400": {
            "description": "Zod validation / domain rules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponseDto"
                }
              }
            }
          },
          "409": {
            "description": "Registration failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponseDto"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Register user",
        "tags": [
          "Users"
        ]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBodyDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sets httpOnly refresh cookie on path /api/v1/auth. Response wraps `{ success, timestamp, data: { accessToken } }`.",
