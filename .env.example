DATABASE_URL=

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DATABASE=

# Rate limit (HTTP, Redis) — namespace ConfigService: rateLimit
# users-register — POST /users
RATE_LIMIT_USERS_REGISTER_MAX=10
RATE_LIMIT_USERS_REGISTER_WINDOW_SECONDS=3600

# tickets-list — GET /tickets
RATE_LIMIT_TICKETS_LIST_MAX=120
RATE_LIMIT_TICKETS_LIST_WINDOW_SECONDS=60

# tickets-create — POST /tickets
RATE_LIMIT_TICKETS_CREATE_MAX=30
RATE_LIMIT_TICKETS_CREATE_WINDOW_SECONDS=60

# tickets-update — PATCH /tickets/:id
RATE_LIMIT_TICKETS_UPDATE_MAX=60
RATE_LIMIT_TICKETS_UPDATE_WINDOW_SECONDS=60
